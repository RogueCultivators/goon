// TestConcurrentCreate 测试并发创建
func (suite *{{.CapitalizedName}}IntegrationTestSuite) TestConcurrentCreate() {
	concurrency := 10
	done := make(chan bool, concurrency)

	for i := 0; i < concurrency; i++ {
		go func(index int) {
			req := &{{.ModuleName}}.CreateRequest{
				// TODO: 填充测试数据
			}

			body, _ := json.Marshal(req)
			w := httptest.NewRecorder()
			httpReq, _ := http.NewRequest("POST", "/api/v1/{{.ModuleName}}", bytes.NewBuffer(body))
			httpReq.Header.Set("Content-Type", "application/json")

			suite.router.ServeHTTP(w, httpReq)

			assert.Equal(suite.T(), http.StatusOK, w.Code)
			done <- true
		}(i)
	}

	// 等待所有请求完成
	for i := 0; i < concurrency; i++ {
		<-done
	}

	// 验证数据库中的记录数
	var count int64
	suite.db.Model(&{{.ModuleName}}.{{.CapitalizedName}}{}).Count(&count)
	assert.Equal(suite.T(), int64(concurrency), count)
}

