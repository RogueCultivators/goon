// {{.CapitalizedName}}IntegrationTestSuite 集成测试套件
type {{.CapitalizedName}}IntegrationTestSuite struct {
	suite.Suite
	db     *gorm.DB
	router *gin.Engine
}

// SetupSuite 在所有测试开始前执行一次
func (suite *{{.CapitalizedName}}IntegrationTestSuite) SetupSuite() {
	// 设置测试模式
	gin.SetMode(gin.TestMode)

	// 连接测试数据库
	cfg := &config.DatabaseConfig{
		Host:     "localhost",
		Port:     5432,
		User:     "test",
		Password: "test",
		DBName:   "test_db",
		SSLMode:  "disable",
	}

	db, err := database.Connect(cfg)
	if err != nil {
		suite.T().Fatalf("连接测试数据库失败: %v", err)
	}
	suite.db = db

	// 自动迁移
	err = suite.db.AutoMigrate(&{{.ModuleName}}.{{.CapitalizedName}}{})
	if err != nil {
		suite.T().Fatalf("数据库迁移失败: %v", err)
	}

	// 设置路由
	suite.router = router.SetupRouter(suite.db)
}

// TearDownSuite 在所有测试结束后执行一次
func (suite *{{.CapitalizedName}}IntegrationTestSuite) TearDownSuite() {
	// 清理测试数据
	suite.db.Exec("DROP TABLE IF EXISTS {{.ModuleName}}s")
	
	// 关闭数据库连接
	sqlDB, _ := suite.db.DB()
	sqlDB.Close()
}

// SetupTest 在每个测试开始前执行
func (suite *{{.CapitalizedName}}IntegrationTestSuite) SetupTest() {
	// 清空表数据
	suite.db.Exec("TRUNCATE TABLE {{.ModuleName}}s RESTART IDENTITY CASCADE")
}

