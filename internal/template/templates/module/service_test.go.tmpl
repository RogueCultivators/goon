// Mock{{.CapitalizedName}}Repository 是 {{.CapitalizedName}}Repository 的 mock
type Mock{{.CapitalizedName}}Repository struct {
	mock.Mock
}

func (m *Mock{{.CapitalizedName}}Repository) FindAll() ([]{{.CapitalizedName}}, error) {
	args := m.Called()
	return args.Get(0).([]{{.CapitalizedName}}), args.Error(1)
}

func (m *Mock{{.CapitalizedName}}Repository) FindByID(id uint) (*{{.CapitalizedName}}, error) {
	args := m.Called(id)
	if args.Get(0) == nil {
		return nil, args.Error(1)
	}
	return args.Get(0).(*{{.CapitalizedName}}), args.Error(1)
}

func (m *Mock{{.CapitalizedName}}Repository) Create(entity *{{.CapitalizedName}}) error {
	args := m.Called(entity)
	return args.Error(0)
}

func (m *Mock{{.CapitalizedName}}Repository) Update(entity *{{.CapitalizedName}}) error {
	args := m.Called(entity)
	return args.Error(0)
}

func (m *Mock{{.CapitalizedName}}Repository) Delete(id uint) error {
	args := m.Called(id)
	return args.Error(0)
}

func TestServiceList(t *testing.T) {
	mockRepo := new(Mock{{.CapitalizedName}}Repository)
	service := NewService(mockRepo)

	expected := []{{.CapitalizedName}}{
		{ID: 1},
		{ID: 2},
	}
	mockRepo.On("FindAll").Return(expected, nil)

	result, err := service.List()

	assert.NoError(t, err)
	assert.Equal(t, expected, result)
	mockRepo.AssertExpectations(t)
}

