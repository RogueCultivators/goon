// 构建提示词方法
func (s *DocumentationSkill) buildDocPrompt(content, docType, format, language string) string {
	return fmt.Sprintf(`请为以下代码生成%s文档，格式：%s，语言：%s

代码：
%s

要求：
1. 文档应该清晰、准确、易懂
2. 包含必要的示例和用法说明
3. 遵循%s格式规范
4. 使用%s语言编写

请只返回文档内容。`, docType, format, language, content, format, language)
}

func (s *TestGenerationSkill) buildTestPrompt(code, testType, framework string, coverage int) string {
	return fmt.Sprintf(`请为以下代码生成%s测试，使用%s框架，目标覆盖率：%d%%

代码：
%s

要求：
1. 生成完整的测试用例
2. 包含正常情况和边界情况测试
3. 使用%s框架的最佳实践
4. 确保测试覆盖率达到%d%%
5. 包含必要的mock和断言

请只返回测试代码。`, testType, framework, coverage, code, framework, coverage)
}

func (s *APIDocsSkill) buildAPIDocPrompt(code, format, version string, includeExamples bool) string {
	exampleText := ""
	if includeExamples {
		exampleText = "包含请求和响应示例"
	}

	return fmt.Sprintf(`请为以下API代码生成%s格式的文档，版本：%s

代码：
%s

要求：
1. 生成完整的API规范
2. 包含所有端点的详细描述
3. 定义请求和响应模型
4. %s
5. 遵循%s规范

请只返回文档内容。`, format, version, code, exampleText, format)
}

// 后处理方法
func (s *DocumentationSkill) postProcessDoc(doc, format string) string {
	// 根据格式进行后处理
	return strings.TrimSpace(doc)
}

func (s *TestGenerationSkill) postProcessTest(test, framework string) string {
	// 根据框架进行后处理
	return strings.TrimSpace(test)
}

func (s *APIDocsSkill) postProcessAPIDoc(doc, format string) string {
	// 根据格式进行后处理
	return strings.TrimSpace(doc)
}

