port: 8080

log:
  level: info          # debug, info, warn, error
  format: json         # json, text
  output: console      # console, file, both
  file_path: logs/app.log
  add_source: false

database:
  host: localhost
  port: 5432
  user: postgres
  password: postgres
  dbname: {{.ProjectName}}
  sslmode: disable
  max_idle: 10
  max_open: 100
