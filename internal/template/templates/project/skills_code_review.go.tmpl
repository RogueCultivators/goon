// autoFixIssues 自动修复问题
func (s *CodeReviewSkill) autoFixIssues(ctx context.Context, code string, issues []ReviewIssue, language string) (string, error) {
	if !s.config.Skills.CodeReview.AutoFix {
		return "", fmt.Errorf("自动修复功能未启用")
	}

	// 过滤出可修复的问题
	var fixableIssues []ReviewIssue
	for _, issue := range issues {
		if issue.Fixable {
			fixableIssues = append(fixableIssues, issue)
		}
	}

	if len(fixableIssues) == 0 {
		return "", fmt.Errorf("没有可自动修复的问题")
	}

	// 构建修复提示词
	prompt := s.buildFixPrompt(code, fixableIssues, language)

	// 调用AI服务进行修复
	fixedCode, err := s.callAIService(ctx, prompt)
	if err != nil {
		return "", fmt.Errorf("调用AI修复服务失败: %w", err)
	}

	return fixedCode, nil
}

// buildFixPrompt 构建修复提示词
func (s *CodeReviewSkill) buildFixPrompt(code string, issues []ReviewIssue, language string) string {
	var issueDescriptions []string
	for _, issue := range issues {
		issueDescriptions = append(issueDescriptions,
			fmt.Sprintf("第%d行：%s - %s", issue.Line, issue.Message, issue.Suggestion))
	}

	return fmt.Sprintf(`请修复以下%s代码中的问题：

原始代码：
```%s
%s
```

需要修复的问题：
%s

请返回修复后的完整代码，只返回代码，不要包含解释。`,
		language, language, code, strings.Join(issueDescriptions, "\n"))
}