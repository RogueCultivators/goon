package skills

import (
	"context"
	"fmt"
	"strings"

	"{{.ModuleName}}/pkg/logger"
)

// CodeReviewSkill 代码审查技能
type CodeReviewSkill struct {
	config *Config
	logger *logger.Logger
}

// NewCodeReviewSkill 创建代码审查技能
func NewCodeReviewSkill(config *Config, logger *logger.Logger) *CodeReviewSkill {
	return &CodeReviewSkill{
		config: config,
		logger: logger,
	}
}

// Name 返回技能名称
func (s *CodeReviewSkill) Name() string {
	return "code_review"
}

// Description 返回技能描述
func (s *CodeReviewSkill) Description() string {
	return "AI驱动的代码审查技能，自动检测代码质量问题并提供改进建议"
}

// Validate 验证输入参数
func (s *CodeReviewSkill) Validate(input *SkillInput) error {
	if input.Type != "code" {
		return fmt.Errorf("代码审查技能只支持 code 类型输入")
	}
	if strings.TrimSpace(input.Content) == "" {
		return fmt.Errorf("代码内容不能为空")
	}
	return nil
}

// Execute 执行代码审查
func (s *CodeReviewSkill) Execute(ctx context.Context, input *SkillInput) (*SkillOutput, error) {
	s.logger.Info("开始执行代码审查", "content_length", len(input.Content))

	// 解析审查参数
	language := s.getParameter(input, "language", "go")
	severity := s.getParameter(input, "severity", "medium") // low, medium, high
	autoFix := s.getBoolParameter(input, "auto_fix", s.config.Skills.CodeReview.AutoFix)

	// 构建审查提示词
	prompt := s.buildReviewPrompt(input.Content, language, severity)

	// 调用AI服务进行代码审查
	reviewResult, err := s.callAIService(ctx, prompt)
	if err != nil {
		return nil, fmt.Errorf("AI服务调用失败: %w", err)
	}

	// 解析审查结果
	issues := s.parseReviewResult(reviewResult)

	// 如果启用自动修复，尝试修复问题
	var fixedCode string
	if autoFix && len(issues) > 0 {
		fixedCode, err = s.autoFixIssues(ctx, input.Content, issues, language)
		if err != nil {
			s.logger.Warn("自动修复失败", "error", err)
		}
	}

	return &SkillOutput{
		Type:    "text",
		Content: reviewResult,
		Metadata: map[string]interface{}{
			"language":     language,
			"severity":     severity,
			"issues_count": len(issues),
			"auto_fix":     autoFix,
			"fixed_code":   fixedCode,
			"issues":       issues,
		},
		Success: true,
	}, nil
}

// ReviewIssue 代码审查问题
type ReviewIssue struct {
	Type        string `json:"type"`        // bug, style, performance, security
	Severity    string `json:"severity"`    // low, medium, high, critical
	Line        int    `json:"line"`        // 问题所在行号
	Column      int    `json:"column"`      // 问题所在列号
	Message     string `json:"message"`     // 问题描述
	Suggestion  string `json:"suggestion"`  // 修复建议
	Rule        string `json:"rule"`        // 违反的规则
	Fixable     bool   `json:"fixable"`     // 是否可自动修复
}

// getParameter 获取字符串参数
func (s *CodeReviewSkill) getParameter(input *SkillInput, key, defaultValue string) string {
	if value, exists := input.Parameters[key]; exists {
		if str, ok := value.(string); ok {
			return str
		}
	}
	return defaultValue
}

// getBoolParameter 获取布尔参数
func (s *CodeReviewSkill) getBoolParameter(input *SkillInput, key string, defaultValue bool) bool {
	if value, exists := input.Parameters[key]; exists {
		if b, ok := value.(bool); ok {
			return b
		}
	}
	return defaultValue
}

// buildReviewPrompt 构建审查提示词
func (s *CodeReviewSkill) buildReviewPrompt(code, language, severity string) string {
	return fmt.Sprintf(`请对以下%s代码进行详细审查，检查级别：%s

代码：
```%s
%s
```

请检查以下方面：
1. 代码质量和最佳实践
2. 潜在的bug和逻辑错误
3. 性能问题
4. 安全漏洞
5. 代码风格和规范
6. 可维护性和可读性

对于每个问题，请提供：
- 问题类型（bug/style/performance/security）
- 严重程度（low/medium/high/critical）
- 具体位置（行号）
- 问题描述
- 修复建议
- 是否可自动修复

请以结构化的格式返回结果。`, language, severity, language, code)
}

